# React Native / Expo artifacts (should not exist in Kotlin projects)
node_modules/
.expo/
.bundle/
ios/
babel.config.js
metro.config.js
package-lock.json
tsconfig.json
app.json

# Gradle
.gradle/
build/
local.properties

# Android
*.apk
*.aab
*.dex
*.class
*.log

# Signing — the Play upload keystore is injected by the Rork AAB export at
# build time and must never live in the repo (its absolute sandbox path
# breaks the export build environment).
*.jks
*.keystore

# IDE
.idea/
*.iml
.vscode/

# macOS
.DS_Store
*.swp
*~

# Rork
.rork/
.env
rork-eslint.config.js
app/src/main/java/**/Config.kt
